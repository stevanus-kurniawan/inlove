# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/tribute

# Admin login (change in production)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Secret used to sign the admin session cookie (use a long random string)
ADMIN_SESSION_SECRET=

# Optional: require SSL for pg (e.g. some hosted Postgres)
# DATABASE_SSL=true

# --- Docker (docker compose) ---
# Compose sets DATABASE_URL for the bundled Postgres service.
# Copy this file to .env and set ADMIN_USER, ADMIN_PASSWORD, ADMIN_SESSION_SECRET (do not commit .env).
# Or pass vars when starting: ADMIN_SESSION_SECRET=... docker compose up --build
# App is published on host port 3005 → http://localhost:3005
